@using magero_store.ViewModels
@model CartViewModel

@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col">
        <h1 class="display-4">Shopping Cart</h1>
    </div>
</div>

<div class="cart-container">
    @if (Model != null && Model.Items.Any())
    {
        <div class="cart-items">
            @foreach (var item in Model.Items)
            {
                <div class="cart-item card mb-3">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-2">
                                <img src="@item.ImageUrl" class="img-fluid" alt="@item.ProductName" />
                            </div>
                            <div class="col-md-10">
                                <h5 class="card-title">@item.ProductName</h5>
                                <p class="card-text">@item.ProductDescription</p>
                                <p class="card-text">Price: @item.UnitPrice.ToString("C")</p>
                                <p class="card-text">Quantity: @item.Quantity</p>
                                <p class="card-text"><strong>Subtotal: @item.Subtotal.ToString("C")</strong></p>
                                <form asp-action="RemoveFromCart" asp-controller="Cart" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-danger">Remove</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
            <div class="cart-summary card">
                <div class="card-body">
                    <h5 class="card-title">Cart Summary</h5>
                    <p class="card-text">Items: @Model.ItemCount</p>
                    <p class="card-text"><strong>Total: @Model.Total.ToString("C")</strong></p>
                    <a asp-action="Checkout" asp-controller="Cart" class="btn btn-success">Proceed to Checkout</a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Your cart is empty. <a asp-controller="Products" asp-action="Index">Continue shopping</a>
        </div>
    }
</div>