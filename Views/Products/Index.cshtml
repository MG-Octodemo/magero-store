@using magero_store.Models
@model IEnumerable<Product>
@{
    ViewData["Title"] = "Products";
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col">
        <h1 class="display-4">Our Products</h1>
        <form asp-action="Index" asp-controller="Products" method="get" class="mb-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <select name="category" class="form-select" onchange="this.form.submit()">
                        <option value="">Todas las categorías</option>
                        @if (ViewBag.Categories != null)
                        {
                            @foreach (var cat in ViewBag.Categories as List<string>)
                            {
                                <option value="@cat" @(ViewBag.CurrentCategory == cat ? "selected" : "")>@cat</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Buscar productos..." value="@ViewBag.CurrentSearchTerm">
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100" type="submit">Buscar</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row g-4">
    @foreach (var product in Model)
    {
        <div class="col-md-3">
            <div class="card h-100 product">
                <div class="card-img-wrapper">
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" />
                </div>
                <div class="card-body">
                    <h5 class="card-title">@product.Name</h5>
                    <span class="badge bg-secondary mb-2">@product.Category</span>
                    <p class="card-text text-muted">@product.Description</p>
                    <div class="mt-auto">
                        <p class="price h4 mb-3">$@product.Price.ToString("0.00")</p>
                        <form asp-action="AddToCart" asp-controller="Cart" method="post">
                            <input type="hidden" name="productId" value="@product.Id" />
                            <div class="input-group mb-3">
                                <select name="quantity" class="form-select">
                                    @for (int i = 1; i <= 10; i++)
                                    {
                                        <option value="@i">@i</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-warning">Add to Cart</button>
                            </div>
                        </form>
                        <a href="@Url.Action("Details", "Products", new { id = product.Id })" 
                           class="btn btn-primary w-100">View Details</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Additional JavaScript for future enhancements can be added here
    </script>
}