@using magero_store.Models
@model magero_store.Models.Product

@{
    ViewData["Title"] = Model.Nombre;
    Layout = "_Layout";
}

<h1>@Model.Nombre</h1>

<div>
    <img src="@Model.UrlImagen" alt="@Model.Nombre" />
</div>

<div>
    <h2>Price: @Model.Precio.ToString("C")</h2>
    <p>@Model.Descripcion</p>
</div>

<form asp-action="AddToCart" asp-controller="Cart">
    <input type="hidden" name="productId" value="@Model.Id" />
    <label for="quantity">Quantity:</label>
    <input type="number" name="quantity" id="quantity" value="1" min="1" />
    <button type="submit">Add to Cart</button>
</form>

<a asp-controller="Products" asp-action="Index">Back to Products</a>